{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Home",
  "version": "1.0.0",
  "identifier": "com.aihome.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Home",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [
      "../../../bin",
      "../../../lib",
      "../../../scripts",
      "../../../package.json",
      "../../../package-lock.json"
    ],
    "targets": [
      "nsis",
      "msi",
      "deb",
      "rpm",
      "appimage",
      "app",
      "dmg"
    ],
    "createUpdaterArtifacts": false,
    "publisher": "AI Home Team",
    "homepage": "https://github.com/example/ai-home",
    "copyright": "Copyright (c) 2026 AI Home Team",
    "license": "MIT",
    "category": "DeveloperTool",
    "shortDescription": "Local desktop launcher for AI Home CLI profiles and sessions.",
    "longDescription": "AI Home Desktop wraps account, migration, and audit workflows from AI Home CLI in a cross-platform GUI.",
    "windows": {
      "digestAlgorithm": "sha256",
      "certificateThumbprint": null,
      "timestampUrl": "https://timestamp.digicert.com",
      "tsp": true,
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": true,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "frameworks": [],
      "files": {}
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ],
        "section": "utils",
        "priority": "optional"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ],
        "release": "1"
      }
    }
  }
}
