{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Home",
  "version": "1.0.0",
  "identifier": "com.aihome.desktop",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Home",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "AI Home Team",
    "category": "DeveloperTool",
    "shortDescription": "Local desktop launcher for AI Home CLI profiles and sessions.",
    "longDescription": "AI Home Desktop wraps account, migration, and audit workflows from AI Home CLI in a cross-platform GUI.",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  }
}
